        "d = {\"name\": \"John\", \"age\": 20}\n",
        "\n",
        "# add / update\n",
        "d[\"age\"] = 21\n",
        "d[\"city\"] = \"Delhi\"\n",
        "\n",
        "# access\n",
        "print(d[\"name\"])\n",
        "print(d.get(\"marks\", \"Not Found\"))\n",
        "\n",
        "# remove\n",
        "del d[\"age\"]\n",
        "d.pop(\"city\")\n",
        "\n",
        "# loop\n",
        "for key, value in d.items():\n",
        "    print(key, \":\", value)\n",
        "\n",
        "print(d.keys())\n",
        "print(d.values())\n",
        "print(d.items())"
